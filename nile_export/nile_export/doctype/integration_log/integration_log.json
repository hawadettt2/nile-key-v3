{
    "doctype": "DocType",
    "name": "Integration Log",
    "module": "nile_export",
    "fields": [
        {"label": "Log ID", "fieldname": "log_id", "fieldtype": "Data", "reqd": 1},
        {"label": "Company", "fieldname": "company", "fieldtype": "Link", "options": "Company"},
        {"label": "Integration Target", "fieldname": "integration_target", "fieldtype": "Data"},
        {"label": "Document Type", "fieldname": "document_type", "fieldtype": "Link", "options": "DocType"},
        {"label": "Document Name", "fieldname": "document_name", "fieldtype": "Data"},
        {"label": "Request Type", "fieldname": "request_type", "fieldtype": "Select", "options": "API Call\nWebhook\nImport\nExport"},
        {"label": "Status", "fieldname": "status", "fieldtype": "Select", "options": "Pending\nSuccess\nFailed\nRetry"},
        {"label": "Workflow State", "fieldname": "workflow_state", "fieldtype": "Data"},
        {"label": "Assigned To", "fieldname": "assigned_to", "fieldtype": "Link", "options": "User"},
        {"label": "Priority", "fieldname": "priority", "fieldtype": "Select", "options": "Low\nMedium\nHigh\nUrgent"},
        {"label": "Request Timestamp", "fieldname": "request_timestamp", "fieldtype": "Datetime"},
        {"label": "Response Timestamp", "fieldname": "response_timestamp", "fieldtype": "Datetime"},
        {"label": "Idempotency Key", "fieldname": "idempotency_key", "fieldtype": "Data"},
        {"label": "Request Payload", "fieldname": "request_payload", "fieldtype": "Code", "options": "JSON"},
        {"label": "Response Payload", "fieldname": "response_payload", "fieldtype": "Code", "options": "JSON"},
        {"label": "Error Message", "fieldname": "error_message", "fieldtype": "Small Text"},
        {"label": "Retry Count", "fieldname": "retry_count", "fieldtype": "Int"},
        {"label": "Notes", "fieldname": "notes", "fieldtype": "Text Editor"}
    ]
}