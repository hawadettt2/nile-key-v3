{
    "doctype": "DocType",
    "name": "Export Shipment",
    "module": "Nile Export",
    "custom": 1,
    "engine": "InnoDB",
    "fields": [
        {
            "label": "Shipment ID",
            "fieldname": "shipment_id",
            "fieldtype": "Data",
            "reqd": 1,
            "unique": 1
        },
        {
            "label": "Supplier",
            "fieldname": "supplier",
            "fieldtype": "Link",
            "options": "Supplier",
            "reqd": 1
        },
        {
            "label": "Importer",
            "fieldname": "importer",
            "fieldtype": "Link",
            "options": "Importer",
            "reqd": 1
        },
        {
            "label": "Destination Country",
            "fieldname": "destination_country",
            "fieldtype": "Link",
            "options": "Country"
        },
        {
            "label": "Shipping Line",
            "fieldname": "shipping_line",
            "fieldtype": "Link",
            "options": "Shipping Line"
        },
        {
            "label": "Container Number",
            "fieldname": "container_number",
            "fieldtype": "Data"
        },
        {
            "label": "Estimated Arrival Date",
            "fieldname": "estimated_arrival_date",
            "fieldtype": "Date"
        },
        {
            "label": "Status",
            "fieldname": "status",
            "fieldtype": "Select",
            "options": "Pending Inspection\nIn Transit\nCustoms Clearance\nShipped\nDelivered",
            "default": "Pending Inspection"
        },
        {
            "label": "Documents",
            "fieldname": "documents",
            "fieldtype": "Table",
            "options": "Export Document"
        }
    ]
}